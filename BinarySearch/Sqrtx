Time complexity=o(logn)
space complexity=o(1)
class Solution {
public:
    int mySqrt(int x) {
        long long left=0,right=x;
        int ans=0;
        while(left<=right){
            long long mid=left+(right-left)/2;
            if(mid*mid==x){
                return mid;
            }
            if(mid*mid>x){
                right=mid-1;
            }else{
                ans=mid;
                left=mid+1;
            }
        }
    return ans;
    }
};
